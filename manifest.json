{
    "manifest_version": 3,
    "name": "Cookie Reject",
    "version": "1.0.0",
    "description": "Automatically reject cookie consent banners on every website. No more annoying pop-ups.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "downloads",
        "tabs",
        "nativeMessaging"
    ],
    "options_page": "pages/options/options.html",
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "src/background/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/content.js"
            ],
            "css": [
                "src/content/hide-banners.css"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "action": {
        "default_popup": "pages/popup/popup.html",
        "default_icon": {
            "16": "assets/icons/icon16.png",
            "48": "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        }
    },
    "icons": {
        "16": "assets/icons/icon16.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    }
}